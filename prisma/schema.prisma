generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  emailVerified     DateTime?
  password          String?
  firstName         String             @default("")
  lastName          String             @default("")
  phone             String?
  country           String?
  profileImageUrl   String?
  role              Role               @default(REGISTERED_CLIENT)
  isActive          Boolean            @default(true)
  totpEnabled       Boolean            @default(false)
  totpSecret        String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  image             String?
  name              String?
  accounts          Account[]
  auditLogs         AuditLog[]
  bookings          Booking[]
  donations         Donation[]
  galleryImages     GalleryImage[]
  messages          Message[]
  notifications     Notification[]
  orders            Order[]
  reviews           Review[]
  savedItems        SavedItem[]
  sessions          Session[]
  talentApplication TalentApplication?
  talentProfile     TalentProfile?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  imageUrl    String?
  createdAt   DateTime  @default(now())
  products    Product[]
}

model ExperienceCategory {
  id          String       @id @default(cuid())
  name        String       @unique
  slug        String       @unique
  description String?
  createdAt   DateTime     @default(now())
  experiences Experience[]
}

model Collection {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  products    Product[]
}

model Product {
  id              String         @id @default(cuid())
  name            String
  slug            String         @unique
  description     String?
  artistName      String?
  artistBio       String?
  price           Decimal        @db.Decimal(10, 2)
  compareAtPrice  Decimal?       @db.Decimal(10, 2)
  categoryId      String?
  collectionId    String?
  medium          String?
  dimensions      String?
  weight          Decimal?       @db.Decimal(8, 2)
  inventoryType   InventoryType  @default(BATCH)
  stockQuantity   Int            @default(1)
  status          ProductStatus  @default(DRAFT)
  featured        Boolean        @default(false)
  primaryImageUrl String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  cartItems       CartItem[]
  orderItems      OrderItem[]
  category        Category?      @relation(fields: [categoryId], references: [id])
  collection      Collection?    @relation(fields: [collectionId], references: [id])
  images          ProductImage[]
  reviews         Review[]
  savedItems      SavedItem[]
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  altText   String?
  position  Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Cart {
  id        String     @id @default(cuid())
  sessionId String?    @unique
  userId    String?    @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     CartItem[]
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  productId String
  quantity  Int     @default(1)
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
}

model Order {
  id             String      @id @default(cuid())
  reference      String      @unique
  userId         String
  status         OrderStatus @default(PENDING)
  subtotal       Decimal     @db.Decimal(10, 2)
  shippingCost   Decimal?    @db.Decimal(10, 2)
  total          Decimal     @db.Decimal(10, 2)
  recipientName  String
  addressLine1   String
  addressLine2   String?
  city           String
  state          String?
  postalCode     String
  country        String
  trackingNumber String?
  carrier        String?
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  user           User        @relation(fields: [userId], references: [id])
  items          OrderItem[]
  payments       Payment[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

model Experience {
  id               String             @id @default(cuid())
  title            String
  slug             String             @unique
  shortDescription String?
  description      String?
  location         String?
  durationHours    Decimal?           @db.Decimal(5, 2)
  pricePerPerson   Decimal?           @db.Decimal(10, 2)
  groupPrice       Decimal?           @db.Decimal(10, 2)
  minGroupSize     Int                @default(1)
  maxGroupSize     Int                @default(10)
  languages        String[]
  meetingPoint     String?
  included         String[]
  excluded         String[]
  whatToBring      String[]
  categoryId       String?
  bookingType      BookingType        @default(DIRECT)
  primaryImageUrl  String?
  status           ExperienceStatus   @default(DRAFT)
  featured         Boolean            @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  category         ExperienceCategory? @relation(fields: [categoryId], references: [id])
  slots            AvailabilitySlot[]
  bookings         Booking[]
  images           ExperienceImage[]
  reviews          Review[]
}

model ExperienceImage {
  id           String     @id @default(cuid())
  experienceId String
  url          String
  altText      String?
  position     Int        @default(0)
  experience   Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
}

model AvailabilitySlot {
  id           String     @id @default(cuid())
  experienceId String
  date         DateTime   @db.Date
  status       SlotStatus @default(AVAILABLE)
  capacity     Int
  booked       Int        @default(0)
  guideEmail   String?
  guideName    String?
  experience   Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  bookings     Booking[]
}

model Booking {
  id              String            @id @default(cuid())
  reference       String            @unique
  userId          String?
  experienceId    String
  slotId          String?
  guestName       String
  guestEmail      String
  guestPhone      String?
  groupSize       Int
  preferredDate   DateTime          @db.Date
  alternateDate   DateTime?         @db.Date
  language        String?
  specialRequests String?
  status          BookingStatus     @default(PENDING)
  adminNote       String?
  depositAmount   Decimal?          @db.Decimal(10, 2)
  depositPaid     Boolean           @default(false)
  cancelReason    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  experience      Experience        @relation(fields: [experienceId], references: [id])
  slot            AvailabilitySlot? @relation(fields: [slotId], references: [id])
  user            User?             @relation(fields: [userId], references: [id])
  payments        Payment[]
}

model ConservationCampaign {
  id              String         @id @default(cuid())
  name            String
  slug            String         @unique
  description     String?
  impactStatement String?
  goalAmount      Decimal        @db.Decimal(12, 2)
  raisedAmount    Decimal        @default(0) @db.Decimal(12, 2)
  donorCount      Int            @default(0)
  imageUrl        String?
  status          CampaignStatus @default(ACTIVE)
  featured        Boolean        @default(false)
  impactTiers     Json?
  createdAt       DateTime       @default(now())
  donations       Donation[]
}

model Donation {
  id         String                @id @default(cuid())
  reference  String                @unique
  userId     String?
  campaignId String?
  amount     Decimal               @db.Decimal(10, 2)
  currency   String                @default("USD")
  purpose    DonationPurpose       @default(GENERAL)
  frequency  DonationFreq          @default(ONE_TIME)
  anonymous  Boolean               @default(false)
  donorName  String?
  donorEmail String
  status     PaymentStatus         @default(PENDING)
  gatewayRef String?
  receiptUrl String?
  createdAt  DateTime              @default(now())
  campaign   ConservationCampaign? @relation(fields: [campaignId], references: [id])
  user       User?                 @relation(fields: [userId], references: [id])
}

model Payment {
  id         String         @id @default(cuid())
  orderId    String?
  bookingId  String?
  amount     Decimal        @db.Decimal(10, 2)
  currency   String         @default("USD")
  gateway    PaymentGateway
  gatewayRef String?        @unique
  status     PaymentStatus  @default(PENDING)
  capturedAt DateTime?
  refundedAt DateTime?
  createdAt  DateTime       @default(now())
  booking    Booking?       @relation(fields: [bookingId], references: [id])
  order      Order?         @relation(fields: [orderId], references: [id])
}

model BlogPost {
  id               String       @id @default(cuid())
  title            String
  slug             String       @unique
  excerpt          String?
  content          String
  category         BlogCategory @default(STORY)
  tags             String[]
  authorId         String?
  featuredImageUrl String?
  seoTitle         String?
  seoDesc          String?
  viewCount        Int          @default(0)
  featured         Boolean      @default(false)
  published        Boolean      @default(false)
  publishedAt      DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Review {
  id              String      @id @default(cuid())
  userId          String?
  productId       String?
  experienceId    String?
  reviewerName    String
  reviewerCountry String?
  rating          Int
  comment         String
  approved        Boolean     @default(false)
  featured        Boolean     @default(false)
  createdAt       DateTime    @default(now())
  experience      Experience? @relation(fields: [experienceId], references: [id])
  product         Product?    @relation(fields: [productId], references: [id])
  user            User?       @relation(fields: [userId], references: [id])
}

model SavedItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model ContactInquiry {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  status    InquiryStatus @default(NEW)
  ipAddress String?
  staffNote String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Conversation {
  id         String     @id @default(cuid())
  topic      String?
  status     ConvStatus @default(OPEN)
  assignedTo String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  messages   Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String?
  senderName     String
  content        String
  isStaff        Boolean      @default(false)
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User?        @relation(fields: [senderId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String   @default("INFO")
  ctaUrl    String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TalentApplication {
  id                 String         @id @default(cuid())
  reference          String         @unique
  userId             String         @unique
  firstName          String
  lastName           String
  email              String
  phone              String?
  ageRange           String?
  gender             String?
  location           String?
  applicantCategory  TalentCategory
  talentArea         TalentArea
  experienceDesc     String
  motivation         String
  availability       String?
  accessibilityNeeds String?
  status             AppStatus      @default(PENDING)
  staffFeedback      String?
  preferredContact   String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  program            String         @default("TALENT_DEVELOPMENT")
  user               User           @relation(fields: [userId], references: [id])
}

model GalleryImage {
  id          String   @id @default(cuid())
  imageUrl    String
  caption     String?
  sortOrder   Int      @default(0)
  published   Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  createdBy   User?    @relation(fields: [createdById], references: [id])
}

model TalentProfile {
  id             String         @id @default(cuid())
  userId         String         @unique
  displayName    String
  bio            String?
  talentArea     TalentArea
  category       TalentCategory
  imageUrl       String?
  portfolioItems Json?
  published      Boolean        @default(false)
  featured       Boolean        @default(false)
  createdAt      DateTime       @default(now())
  user           User           @relation(fields: [userId], references: [id])
}

model TourOperator {
  id          String            @id @default(cuid())
  userId      String            @unique
  companyName String
  contactName String
  email       String
  phone       String?
  country     String?
  createdAt   DateTime          @default(now())
  requests    OperatorRequest[]
}

model OperatorRequest {
  id              String          @id @default(cuid())
  operatorId      String
  experienceSlug  String?
  requestType     OperatorReqType @default(GROUP_BOOKING)
  estimatedSize   Int
  estimatedDate   DateTime?       @db.Date
  invoiceRequired Boolean         @default(false)
  specialRequests String?
  partnerPrice    Decimal?        @db.Decimal(10, 2)
  itineraryUrl    String?
  status          OperatorStatus  @default(SUBMITTED)
  adminNote       String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  operator        TourOperator    @relation(fields: [operatorId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorEmail String?
  eventType  String
  entityType String
  entityId   String?
  details    String?
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())
  actor      User?    @relation(fields: [actorId], references: [id])
}

model PlatformSetting {
  id        String   @id @default(cuid())
  category  String
  key       String
  value     String
  masked    Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@unique([category, key])
}

model Testimonial {
  id              String   @id @default(cuid())
  reviewerName    String
  reviewerCountry String?
  reviewerRole    String?
  content         String
  rating          Int      @default(5)
  imageUrl        String?
  published       Boolean  @default(false)
  featured        Boolean  @default(false)
  createdAt       DateTime @default(now())
}

enum Role {
  GUEST
  REGISTERED_CLIENT
  TALENT_APPLICANT
  TOUR_OPERATOR
  CONTENT_MANAGER
  OPS_MANAGER
  SUPER_ADMIN
}

enum InventoryType {
  UNIQUE
  BATCH
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  SOLD
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum BookingType {
  DIRECT
  INQUIRY
}

enum ExperienceStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SlotStatus {
  AVAILABLE
  LIMITED
  FULLY_BOOKED
  REQUEST_ONLY
  BLACKOUT
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  REJECTED
}

enum CampaignStatus {
  ACTIVE
  COMPLETED
  PAUSED
  ARCHIVED
}

enum DonationPurpose {
  GENERAL
  REFORESTATION
  COMMUNITY_EDUCATION
  YOUTH_EMPOWERMENT
  CONSERVATION
}

enum DonationFreq {
  ONE_TIME
  MONTHLY
  QUARTERLY
  ANNUALLY
}

enum PaymentGateway {
  MTN_MOMO
  AIRTEL_MONEY
  BANK_TRANSFER
  MANUAL
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum BlogCategory {
  UPDATE
  EVENT
  STORY
  CULTURE
  CONSERVATION
  TESTIMONIAL
}

enum InquiryStatus {
  NEW
  IN_PROGRESS
  CLOSED
}

enum ConvStatus {
  OPEN
  AWAITING_STAFF
  AWAITING_CLIENT
  CLOSED
}

enum TalentCategory {
  YOUTH
  SINGLE_MOTHER
  PERSON_WITH_DISABILITY
  ELDERLY
  PROFESSIONAL_ARTIST
  COMMUNITY_MEMBER
}

enum TalentArea {
  TRADITIONAL_DANCE
  STORYTELLING
  CULTURAL_PERFORMANCE
  MUSIC
  VISUAL_ARTS
  CRAFTS
  OTHER
}

enum AppStatus {
  PENDING
  APPROVED
  REJECTED
  AWAITING_INFO
  ARCHIVED
}

enum OperatorReqType {
  GROUP_BOOKING
  CUSTOM_PACKAGE
}

enum OperatorStatus {
  SUBMITTED
  UNDER_REVIEW
  INVOICE_PENDING
  CONFIRMED
  DECLINED
}
